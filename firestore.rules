rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == 'aiNZh4Myn8Y0KfYkGGrkNNW0HC72';
    }

    // Users collection — own document read/write; admin can read any
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;

      // profile — own only
      match /profile/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // cardProgress — own user or admin (admin reset for other users)
      match /cardProgress/{cardId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }

      // conversationHistory — own only
      match /conversationHistory/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // kiUsage — own only (daily session tracking)
      match /kiUsage/{dateStr} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // settings — own user or admin (admin reset for other users)
      match /settings/{doc} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }

      // partnerRequests — any authenticated user can create, only owner reads/deletes
      match /partnerRequests/{requestId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    // publicStats — absolute path, any authenticated user (partner cross-writes Mark↔Elosy)
    match /users/{uid}/publicStats/data {
      allow read, write: if request.auth != null;
    }

    // globalStats — read-only for any authenticated user (subcollection of users/{uid})
    match /users/{uid}/globalStats/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // incomingCards — absolute path, any authenticated user (sender reads for dupe check, writes to send)
    match /users/{uid}/incomingCards/{cardId} {
      allow read, write: if request.auth != null;
    }

    // userProfiles pendingNotifs — absolute path, any authenticated user (push notifications)
    match /userProfiles/{uid}/pendingNotifs/{notifId} {
      allow read, write: if request.auth != null;
    }

    // Shared card pool — any authenticated user can read, server writes via API (unauthenticated REST)
    match /sharedCards/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth == null;
    }

    // Shared sentence exercise pool — any authenticated user can read, server writes via API
    match /sharedSentences/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth == null;
    }

    // Shared training exercises pool — read by auth users, server writes
    match /sharedExercises/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth == null;
    }

    // Monthly gimmick history — own data only
    match /monthlyGimmick/{userId}/history/{month} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Streak milestone gimmick guard — own data only
    match /streakGimmick/{userId}/milestones/{milestone} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reports — any authenticated user can create; admin (Mark) can read/update/delete
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

  }
}
