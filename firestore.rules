rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == 'aiNZh4Myn8Y0KfYkGGrkNNW0HC72';
    }

    // Users collection
    match /users/{userId} {
      // Own user read/write; admin can read any user document (AdminScreen user list)
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;

      // profile — own only
      match /profile/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // publicStats — any authenticated user (partner cross-writes)
      match /publicStats/{doc} {
        allow read, write: if request.auth != null;
      }

      // incomingCards — any authenticated user (sender needs read for duplicate check + write to send)
      match /incomingCards/{cardId} {
        allow read, write: if request.auth != null;
      }

      // cardProgress — own user only
      match /cardProgress/{cardId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // conversationHistory — own only
      match /conversationHistory/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // kiUsage — own only (daily session tracking)
      match /kiUsage/{dateStr} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // settings — own only (categoryLevels, preferences)
      match /settings/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // partnerRequests — any authenticated user can create (send request), only owner reads/deletes
      match /partnerRequests/{requestId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    // userProfiles — pendingNotifs readable/writable by any authenticated user (push notifications)
    match /userProfiles/{uid} {
      match /pendingNotifs/{notifId} {
        allow read, write: if request.auth != null;
      }
    }

    // Shared card pool — any authenticated user can read, server writes via API (unauthenticated REST)
    match /sharedCards/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth == null;
    }

    // Shared sentence exercise pool — any authenticated user can read, server writes via API
    match /sharedSentences/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth == null;
    }

    // Shared training exercises pool — read by auth users, server writes
    match /sharedExercises/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth == null;
    }

    // Monthly gimmick history — own data only
    match /monthlyGimmick/{userId}/history/{month} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Streak milestone gimmick guard — own data only
    match /streakGimmick/{userId}/milestones/{milestone} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reports — any authenticated user can create; admin (Mark) can read/update/delete
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

  }
}
