rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — own data + publicStats readable by any signed-in user
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // profile subcollection — own only
      match /profile/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // publicStats — any authenticated user can read and write
      // (partner notifications, partner data updates cross-write to other users' publicStats)
      match /publicStats/{doc} {
        allow read, write: if request.auth != null;
      }

      // incomingCards — any authenticated user can read and create
      // (read needed for sender's duplicate check before gifting; create for sending)
      // only owner can delete their own incoming cards
      match /incomingCards/{cardId} {
        allow read, create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // conversationHistory — own only
      match /conversationHistory/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // partnerRequests — any authenticated user can create (send request), only owner reads/deletes
      match /partnerRequests/{requestId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    // Shared card pool — any authenticated user can read, server writes via API (unauthenticated REST)
    match /sharedCards/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth == null;
    }

    // Shared sentence exercise pool — any authenticated user can read, server writes via API
    match /sharedSentences/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth == null;
    }

    // Monthly gimmick history — own data only
    match /monthlyGimmick/{userId}/history/{month} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Streak milestone gimmick guard — own data only
    match /streakGimmick/{userId}/milestones/{milestone} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reports — any authenticated user can create
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
